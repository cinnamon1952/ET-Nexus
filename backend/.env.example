GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.1-8b-instant

# Comma-separated list of frontend origins allowed to call the API.
# Example:
# CORS_ORIGINS=https://your-app.vercel.app,https://your-preview.vercel.app
CORS_ORIGINS=http://localhost:3000

# Optional single-origin alternative if you do not want to use CORS_ORIGINS.
FRONTEND_ORIGIN=http://localhost:3000

# Optional tuning
FEED_REFRESH_TTL_SECONDS=900
MAX_FEED_ARTICLES=12
MAX_STORY_ARC_SUMMARIES=6
MAX_RELATED_ARTICLES=4
INGEST_WITH_GROQ=false
TRANSLATION_CONCURRENCY=2
